name: money-laundering-analysis
services:
  rabbitmq:
    build:
      context: ./src/rabbitmq
      dockerfile: Dockerfile
    container_name: rabbitmq
    environment:
      - RABBITMQ_LOG_LEVELS=error
    networks:
      - money-laundering-analysis-net
    healthcheck:
      interval: 5s
      retries: 10
      start_period: 50s
      test: rabbitmq-diagnostics check_port_connectivity
      timeout: 3s
    ports:
      - 5672:5672
      - 15672:15672

  gateway:
    build:
      context: .
      dockerfile: src/gateway/Dockerfile
    container_name: gateway
    environment:
      - LOG_LEVEL=debug
      - ACCOUNTS_CONFIG_PATH=/app/accounts_queue_config.yaml
    volumes:
      - ./configs/gateway.yaml:/app/config.yaml
      - ./configs/query2/join_account_queue.yaml:/app/accounts_queue_config.yaml
    networks:
      - money-laundering-analysis-net
    depends_on:
      rabbitmq:
        condition: service_healthy

{{- $monitors := 3}}
{{- range $i := until $monitors}}
  monitor_{{$i}}:
    build:
      context: .
      dockerfile: src/cmd/node/Dockerfile
    container_name: monitor_{{$i}}
    environment:
      - LOG_LEVEL=debug
      - CONFIG_PATH=/app/config.yaml
      - SYSTEM_CONFIG_PATH=/app/system.yaml
      - WORKER_PREFIX=monitor
      - ID={{$i}}
      - WORKER_AMOUNT={{$monitors}}
    volumes:
      - ./configs/monitor.yaml:/app/config.yaml
      - ./configs/system.yaml:/app/system.yaml:ro
      - /var/run/docker.sock:/var/run/docker.sock
    networks:
      - money-laundering-analysis-net
    depends_on:
      rabbitmq:
        condition: service_healthy
{{- end}}
{{- range .Clients}}
  client_{{.ID}}:
    build:
      context: .
      dockerfile: src/client/Dockerfile
    container_name: client_{{.ID}}
    environment:
{{- range .EnvSorted}}
      - {{.}}
{{- end}}
    volumes:
      - ./configs/client.yaml:/app/config.yaml
      - ./.data:/app/.data
      - ./.output/client{{.ID}}:/app/.output
{{- range .ExtraVolumes}}
      - {{.}}
{{- end}}
    networks:
      - money-laundering-analysis-net
    depends_on:
      - gateway
{{- end}}
{{- range .Workers}}
  {{.ContainerName}}:
    build:
      context: .
      dockerfile: src/cmd/node/Dockerfile
    container_name: {{.ContainerName}}
    environment:
{{- range .EnvSorted}}
      - {{.}}
{{- end}}
      - SYSTEM_CONFIG_PATH=/app/system.yaml
    volumes:
      - {{.VolumeMapping}}
{{- range .ExtraVolumes}}
      - {{.}}
{{- end}}
      - ./configs/system.yaml:/app/system.yaml:ro
    networks:
      - money-laundering-analysis-net
    depends_on:
      rabbitmq:
        condition: service_healthy
      monitor_0:
        condition: service_started
{{- end}}
networks:
  money-laundering-analysis-net:
    ipam:
      driver: default
      config:
        - subnet: 172.25.125.0/24
